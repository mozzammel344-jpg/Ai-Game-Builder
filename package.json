{
  "name": "Game",
  "version": "1.0.0",
  "main": "main-electron.js",
  "scripts": {
    "start": "node server.js",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3",
    "install": "^0.13.0"
  },
  "build": {
    "appId": "com.architect.game",
    "productName": "ArchitectGame",
